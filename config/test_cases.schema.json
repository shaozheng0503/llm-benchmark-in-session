{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "MiniMax-M3 Test Case Schema",
  "description": "test_cases.json 的 JSON Schema，CI 自动校验",
  "type": "object",
  "required": ["version", "model_under_test", "test_date", "cases"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "SemVer-like 版本号（如 1.3）"
    },
    "description": {"type": "string"},
    "model_under_test": {"type": "string"},
    "test_date": {"type": "string", "format": "date"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/case"}
    }
  },
  "definitions": {
    "case": {
      "type": "object",
      "required": ["id", "category", "name", "prompt", "assertion"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "snake_case 唯一 ID"
        },
        "category": {
          "type": "string",
          "enum": ["smoke", "core", "complex", "safety", "boundary", "real_task", "multilingual", "uncategorized"]
        },
        "name": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1},
        "assertion": {
          "type": "object",
          "description": "断言字典，键为断言类型"
        }
      },
      "additionalProperties": false
    }
  }
}
